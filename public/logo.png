<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="none" stroke="#5A2A5D" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round">
  <!-- Central tall crystal -->
  <polygon points="50,6 62,28 62,58 50,68 38,58 38,28" />
  <!-- Inner facet lines on central crystal -->
  <line x1="50" y1="6" x2="50" y2="68" />
  <line x1="50" y1="28" x2="62" y2="28" />
  <line x1="50" y1="28" x2="38" y2="28" />
  <line x1="44" y1="17" x2="38" y2="28" />
  <line x1="56" y1="17" x2="62" y2="28" />
  <!-- Left crystal / leaf -->
  <polygon points="38,58 20,50 14,72 32,80 50,68" />
  <line x1="38" y1="58" x2="32" y2="80" />
  <line x1="20" y1="50" x2="50" y2="68" />
  <line x1="14" y1="72" x2="50" y2="68" />
  <!-- Right crystal / leaf -->
  <polygon points="62,58 80,50 86,72 68,80 50,68" />
  <line x1="62" y1="58" x2="68" y2="80" />
  <line x1="80" y1="50" x2="50" y2="68" />
  <line x1="86" y1="72" x2="50" y2="68" />
  <!-- Bottom base line -->
  <line x1="14" y1="72" x2="32" y2="80" />
  <line x1="68" y1="80" x2="86" y2="72" />
  <line x1="32" y1="80" x2="68" y2="80" />
</svg>
